# Dependencies
node_modules/

# Build output
dist/

# Environment
.env

# Uploads - ignore files but keep directory structure
uploads/*
!uploads/.gitkeep
!uploads/**/.gitkeep

# Logs
*.log

# Import staging files (CSVs are generated, not committed)
import/staging/*.csv
import/staging/*.md

# Import source files (Excel files are local, not committed)
import/source/*
!import/source/.gitkeep
